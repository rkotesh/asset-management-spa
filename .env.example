# MongoDB Connection String (leave blank to use the local docker MongoDB container)
# MONGODB_URI=

# JWT Auth Secret (use a secure 32+ character string)
JWT_SECRET=

# App settings
FRONTEND_URL=http://localhost:8080

# AWS S3 Configurations
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# SMTP Email Configurations (required for password resets / notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
